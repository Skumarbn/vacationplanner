# Required in production so links and deployment checks use the correct base URL.
APP_URL=http://127.0.0.1:3000

# Optional. When omitted, the app stays in local demo mode.
OPENAI_API_KEY=your_api_key_here

# Optional model override for real OpenAI calls.
OPENAI_MODEL=gpt-5.4-mini

# Optional local server port override.
PORT=3000
